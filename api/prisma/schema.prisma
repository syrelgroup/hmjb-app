generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum EDataStatus {
  SEMUA
  USER
}

enum EPermitStatus {
  PENDING
  DISETUJUI
  DITOLAK
  SELESAI
}

enum EArsipStatus {
  PENDING
  AKTIF
  LUNAS
  PASIF
  BREAK
}

enum EFlaggingStatus {
  PENDING
  FLAGGING
  NON_PENSIUNAN
}

enum EGuaranteeStatus {
  PENDING
  DITERIMA
  DIPINJAM
  DIKEMBALIKAN
}

enum ENominalType {
  RUPIAH
  PERCENT
}

enum ECostType {
  PENAMBAHAN
  PENGURANGAN
}

enum EAbsenceStatus {
  ALPHA
  HADIR
  TERLAMBAT
  CUTI
  PERDIN
  SAKIT
  LEMBUR
  PULANG_CEPAT
}

enum EGBookStatus {
  AKANDATANG
  TELAHDATANG
}

enum EBill {
  BAYAR
  BELUMBAYAR
  PARTIAL
}

model Role {
  id          String      @id @default(uuid())
  name        String
  permission  String      @db.Text
  data_status EDataStatus @default(SEMUA)

  status     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  User       User[]
}

model Position {
  id          String  @id @default(uuid())
  name        String
  description String? @db.Text

  status     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  User       User[]
}

model User {
  id           String  @id @default(uuid())
  fullname     String
  nik          String?
  nip          String?
  phone        String?
  email        String?
  username     String  @unique
  password     String
  salary       Int
  ptkp         String
  absen_method String
  face         String? @db.Text
  photo        String?

  status                Boolean             @default(true)
  created_at            DateTime            @default(now())
  updated_at            DateTime            @default(now())
  Position              Position?           @relation(fields: [positionId], references: [id], onUpdate: Cascade)
  Role                  Role                @relation(fields: [roleId], references: [id], onUpdate: Cascade)
  SubmissionCreated     Submission[]        @relation("SubmissionCreated")
  CollateralCreated     CollateralLending[] @relation("CollateralCreated")
  CollateralApprover    CollateralLending[] @relation("CollateralApprover")
  VisitApprover         Visit[]             @relation("VisitApprover")
  InsentifApprover      Insentif[]          @relation("InsentifApprover")
  DeductionCreate       Deduction[]         @relation("DeductionCreated")
  PermitAbsenceApprover PermitAbsence[]     @relation("PermitAbsenceApprover")
  ReuestMade            PermitFile[]        @relation("RequesterRelation")
  ApprovMade            PermitFile[]        @relation("ApproverRelation")
  PayrollApprover       Payroll[]           @relation("PayrollApprover")
  Insentif              Insentif[]
  Submission            Submission[]
  LogActivities         LogActivities[]
  Visit                 Visit[]
  UserCost              UserCost[]
  Absence               Absence[]
  Payroll               Payroll[]
  roleId                String
  positionId            String?
  PermitAbsence         PermitAbsence[]
  Deduction             Deduction[]
  Billing               Billing[]
}

model SubmissionType {
  id          String  @id @default(uuid())
  name        String
  description String?

  status     Boolean   @default(true)
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  Debitur    Debitur[]
}

model ProductType {
  id          String  @id @default(uuid())
  name        String
  description String?

  status          Boolean           @default(true)
  created_at      DateTime          @default(now())
  updated_at      DateTime          @default(now())
  ProductTypeFile ProductTypeFile[]
  Product         Product[]
}

model ProductTypeFile {
  id   String @id @default(uuid())
  name String
  type String

  status        Boolean     @default(true)
  created_at    DateTime    @default(now())
  updated_at    DateTime    @default(now())
  ProductType   ProductType @relation(fields: [productTypeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  Files         Files[]
  productTypeId String
}

model Product {
  id   String @id @default(uuid())
  name String

  status        Boolean      @default(true)
  created_at    DateTime     @default(now())
  updated_at    DateTime     @default(now())
  ProductType   ProductType  @relation(fields: [productTypeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  Submission    Submission[]
  productTypeId String
  Billing       Billing[]
}

model Debitur {
  id         String    @id @default(uuid())
  cif        String?
  fullname   String
  nik        String    @unique
  birthplace String?
  birthdate  DateTime?
  address    String?   @db.Text
  phone      String?
  email      String?

  status           Boolean        @default(true)
  created_at       DateTime       @default(now())
  updated_at       DateTime       @default(now())
  SubmissionType   SubmissionType @relation(fields: [submissionTypeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  submissionTypeId String
  Submission       Submission[]
  Visit            Visit[]
}

model Mitra {
  id          String  @id @default(uuid())
  name        String
  code        String?
  phone       String?
  email       String?
  address     String?
  pic         String?
  no_contract String?
  drawer_code String?
  description String?
  file        String? @db.Text

  status     Boolean      @default(true)
  created_at DateTime     @default(now())
  updated_at DateTime     @default(now())
  Submission Submission[]
  Billing    Billing[]
  Visit      Visit[]
}

model Submission {
  id               String           @id @default(uuid())
  purpose          String?
  coments          String?          @db.Text
  account_number   String?
  activities       String?          @db.Text
  value            Int
  tenor            Int
  drawer_code      String
  guarantee_status EGuaranteeStatus @default(PENDING)
  doc_status       EGuaranteeStatus @default(PENDING)
  approve_status   EArsipStatus     @default(PENDING)
  flagging_status  EFlaggingStatus  @default(PENDING)

  status            Boolean             @default(true)
  created_at        DateTime            @default(now())
  updated_at        DateTime            @default(now())
  Debitur           Debitur             @relation(fields: [debiturId], references: [id], onUpdate: Cascade)
  Product           Product             @relation(fields: [productId], references: [id], onUpdate: Cascade)
  User              User                @relation(fields: [userId], references: [id], onUpdate: Cascade)
  Mitra             Mitra?              @relation(fields: [mitraId], references: [id], onUpdate: Cascade)
  CreatedBy         User                @relation("SubmissionCreated", fields: [createdById], references: [id], onUpdate: Cascade)
  createdById       String
  debiturId         String
  productId         String
  userId            String
  mitraId           String?
  Files             Files[]
  PermitFileDetail  PermitFileDetail[]
  CollateralLending CollateralLending[]
  Visit             Visit[]
  PayOffice         PayOffice?          @relation(fields: [payOfficeId], references: [id])
  payOfficeId       String?
  Insurance         Insurance?          @relation(fields: [insuranceId], references: [id])
  insuranceId       String?
  Billing           Billing[]
}

model CollateralLending {
  id          String    @id @default(uuid())
  description String?   @db.Text
  start_at    DateTime  @default(now())
  end_at      DateTime?
  file        String?
  return_at   DateTime?

  status       Boolean    @default(true)
  created_at   DateTime   @default(now())
  updated_at   DateTime   @default(now())
  Submission   Submission @relation(fields: [submissionId], references: [id], onUpdate: Cascade)
  CreatedBy    User       @relation("CollateralCreated", fields: [createdById], references: [id], onUpdate: Cascade)
  ApproverBy   User?      @relation("CollateralApprover", fields: [approverById], references: [id], onUpdate: Cascade)
  approverById String?
  createdById  String
  submissionId String
}

model Files {
  id             String @id @default(uuid())
  name           String
  url            String
  allow_download String @db.Text

  created_at        DateTime           @default(now())
  Submission        Submission?        @relation(fields: [submissionId], references: [id], onUpdate: Cascade)
  ProductTypeFile   ProductTypeFile    @relation(fields: [productTypeFileId], references: [id], onUpdate: Cascade)
  submissionId      String?
  productTypeFileId String
  PermitFileDetail  PermitFileDetail[]
}

model PermitFile {
  id            String        @id @default(uuid())
  action        String
  description   String?
  approv_desc   String?
  permit_status EPermitStatus @default(PENDING)
  process_at    DateTime?

  status           Boolean            @default(true)
  created_at       DateTime           @default(now())
  updated_at       DateTime           @default(now())
  Requester        User               @relation("RequesterRelation", fields: [requesterId], references: [id], onUpdate: Cascade)
  Approver         User?              @relation("ApproverRelation", fields: [approverId], references: [id], onUpdate: Cascade)
  requesterId      String
  approverId       String?
  PermitFileDetail PermitFileDetail[]
}

model PermitFileDetail {
  id           String     @id @default(uuid())
  Submission   Submission @relation(fields: [submissionId], references: [id], onUpdate: Cascade)
  Files        Files[]
  submissionId String
  PermitFile   PermitFile @relation(fields: [permitFileId], references: [id])
  permitFileId String
}

model PayOffice {
  id          String  @id @default(uuid())
  name        String
  description String?
  files       String? @db.Text

  status     Boolean      @default(true)
  created_at DateTime     @default(now())
  updated_at DateTime     @default(now())
  Submission Submission[]
}

model Insurance {
  id          String  @id @default(uuid())
  name        String
  description String?
  files       String? @db.Text

  status     Boolean      @default(true)
  created_at DateTime     @default(now())
  updated_at DateTime     @default(now())
  Submission Submission[]
}

model VisitCategory {
  id          String  @id @default(uuid())
  name        String
  description String?

  status     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  Visit      Visit[]
}

model VisitStatus {
  id          String  @id @default(uuid())
  name        String
  color       String?
  description String?

  status     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  Visit      Visit[]
}

model VisitPurpose {
  id          String  @id @default(uuid())
  name        String
  description String?

  status     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  Visit      Visit[]
}

model Visit {
  id            String    @id @default(uuid())
  value         Int
  realize_value Int?      @default(0)
  summary       String?   @db.Text
  coments       String?   @db.Text
  date_plan     DateTime
  date_action   DateTime?
  geo           String?
  files         String?   @db.Text
  next_action   String?   @db.Text

  status          Boolean       @default(true)
  created_at      DateTime      @default(now())
  updated_at      DateTime      @default(now())
  Debitur         Debitur       @relation(fields: [debiturId], references: [id], onUpdate: Cascade)
  User            User          @relation(fields: [userId], references: [id], onUpdate: Cascade)
  VisitCategory   VisitCategory @relation(fields: [visitCategoryId], references: [id], onUpdate: Cascade)
  VisitStatus     VisitStatus?  @relation(fields: [visitStatusId], references: [id], onUpdate: Cascade)
  VisitPurpose    VisitPurpose? @relation(fields: [visitPurposeId], references: [id])
  Submission      Submission?   @relation(fields: [submissionId], references: [id], onUpdate: Cascade)
  ApproverBy      User?         @relation("VisitApprover", fields: [approverById], references: [id], onUpdate: Cascade)
  Mitra           Mitra         @relation(fields: [mitraId], references: [id])
  approverById    String?
  submissionId    String?
  debiturId       String
  userId          String
  visitCategoryId String
  visitStatusId   String?
  visitPurposeId  String?
  mitraId         String
}

model Billing {
  id            String    @id @default(uuid())
  plafond       Int       @default(0)
  tenor         Int       @default(0)
  value         Int       @default(0)
  realize_value Int       @default(0)
  bill_status   EBill     @default(BELUMBAYAR)
  bill_date     DateTime
  name          String?
  pkk           Int       @default(0)
  tung_pkk      Int       @default(0)
  tung_bga      Int       @default(0)
  start_at      DateTime?
  end_at        DateTime?
  col           String?

  status       Boolean     @default(true)
  created_at   DateTime    @default(now())
  updated_at   DateTime    @default(now())
  User         User?       @relation(fields: [userId], references: [id])
  userId       String?
  Submission   Submission? @relation(fields: [submissionId], references: [id])
  submissionId String?
  Mitra        Mitra?      @relation(fields: [mitraId], references: [id])
  mitraId      String?
  Product      Product?    @relation(fields: [productId], references: [id])
  productId    String?
}

model AbsenceConfig {
  id                   String  @id @default(uuid())
  late_deduction       Int     @default(0)
  fast_leave_deduction Int     @default(0)
  alpha_deduction      Int     @default(0)
  shift_start          Int     @default(0)
  shift_end            Int     @default(0)
  shift_tolerance      Int     @default(0)
  last_shift           Int?    @default(0)
  geo_status           Boolean @default(false)
  geo_location         String?
  meter_tolerance      Int?    @default(0)

  updated_at DateTime @default(now())
}

model UserCost {
  id           String       @id @default(uuid())
  name         String
  type         ECostType
  nominal      Float
  nominal_type ENominalType @default(RUPIAH)
  start_at     DateTime     @default(now())
  end_at       DateTime?

  User   User   @relation(fields: [userId], references: [id], onUpdate: Cascade)
  userId String
}

model Absence {
  id                   String         @id @default(uuid())
  method               String
  check_in             DateTime? // jam masuk
  check_out            DateTime? // jam pulang
  geo_in_lat           Decimal?
  geo_in_long          Decimal?
  geo_out_lat          Decimal?
  geo_out_long         Decimal?
  late_deduction       Int            @default(0)
  fast_leave_deduction Int            @default(0)
  lemburan             Int            @default(0)
  alpha_deduction      Int            @default(0)
  absence_status       EAbsenceStatus @default(HADIR)
  description          String?

  status     Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  User       User     @relation(fields: [userId], references: [id], onUpdate: Cascade)
  userId     String
}

model PermitAbsence {
  id            String         @id @default(uuid())
  type          EAbsenceStatus
  description   String?        @db.Text
  file          String?
  start_date    DateTime?
  end_date      DateTime?
  permit_status EPermitStatus  @default(PENDING)

  status       Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now())
  User         User     @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  userId       String
  ApproverBy   User?    @relation("PermitAbsenceApprover", fields: [approverById], references: [id], onUpdate: Cascade)
  approverById String?
}

model CostType {
  id          String    @id @default(uuid())
  name        String
  type        ECostType
  description String?

  status     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
}

model Insentif {
  id             String        @id @default(uuid())
  name           String
  description    String?
  file           String?
  nominal_type   ENominalType  @default(RUPIAH)
  nominal        Float
  approve_status EPermitStatus @default(PENDING)

  status     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  User         User    @relation(fields: [userId], references: [id], onUpdate: Cascade)
  userId       String
  ApproverBy   User?   @relation("InsentifApprover", fields: [approverById], references: [id], onUpdate: Cascade)
  approverById String?
}

model Deduction {
  id           String       @id @default(uuid())
  name         String
  description  String?
  file         String?
  nominal_type ENominalType @default(RUPIAH)
  nominal      Float

  status      Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now())
  User        User     @relation(fields: [userId], references: [id], onUpdate: Cascade)
  userId      String
  CreatedBy   User?    @relation("DeductionCreated", fields: [createdById], references: [id], onUpdate: Cascade)
  createdById String?
}

model Payroll {
  id          String    @id @default(uuid())
  month       Int // 1-12
  year        Int // e.g., 2026
  base_salary Int // Gaji pokok
  allowance   Int       @default(0) // Tunjangan
  insentif    Int       @default(0) // insentif tambahan
  deduction   Int       @default(0) // Total potongan
  notes       String?   @db.Text
  approved_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  User       User    @relation(fields: [userId], references: [id], onUpdate: Cascade)
  Approver   User?   @relation("PayrollApprover", fields: [approverId], references: [id], onUpdate: Cascade)
  approverId String?
  userId     String

  PayrollDetail PayrollDetail[]

  @@unique([userId, month, year])
}

model PayrollDetail {
  id     String   @id @default(uuid())
  name   String // e.g., "Tunjangan Makan", "Potongan BPJS TK", "Deduction Terlambat", "Bonus Insentif"
  type   String // "ALLOWANCE", "DEDUCTION", "BONUS", "PENALTY"
  amount Float
  date   DateTime @default(now())

  Payroll   Payroll @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  payrollId String
}

model GBookType {
  id          String  @id @default(uuid())
  name        String
  description String?

  status     Boolean     @default(true)
  created_at DateTime    @default(now())
  updated_at DateTime    @default(now())
  GuestBook  GuestBook[]
}

model GuestBook {
  id          String       @id @default(uuid())
  name        String
  date        DateTime
  status_come EGBookStatus @default(TELAHDATANG)
  description String?      @db.Text
  file        String?

  status     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  GBookType   GBookType     @relation(fields: [gBookTypeId], references: [id], onUpdate: Cascade)
  gBookTypeId String
  Participant Participant[]
}

model Participant {
  id    String  @id @default(uuid())
  name  String
  phone String?
  email String?
  note  String?

  GuestBook   GuestBook @relation(fields: [guestBookId], references: [id], onUpdate: Cascade)
  guestBookId String
}

model LogActivities {
  id         String   @id @default(uuid())
  method     String
  status     String
  ip         String
  userAgent  String
  User       User     @relation(fields: [userId], references: [id], onUpdate: Cascade)
  userId     String
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
}
